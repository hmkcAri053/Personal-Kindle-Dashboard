# Local development (default file storage)
PORT=3000
STORE_PROVIDER=file
DATA_PATH=backend/data/tasks.json

# Optional: enable CORS when frontend and backend use different domains
# Example:
# ALLOW_ORIGINS=https://your-frontend.web.app,https://your-custom-domain.com
ALLOW_ORIGINS=

# Production (Cloud Run + Firestore)
# STORE_PROVIDER=firestore
# FIRESTORE_COLLECTION=kindle_dashboard
# FIRESTORE_DOC_ID=prod

# QWeather (HeWeather) - 3-day forecast for dashboard weather summary
# For free plan, public host usually works with API key auth:
# QW_API_HOST=devapi.qweather.com
# QW_API_KEY=your_api_key
# QW_LOCATION=珠海
# QW_LANG=en
# QW_UNIT=m
# QW_TIME_ZONE=Asia/Shanghai
# WEATHER_CACHE_MS=10800000
